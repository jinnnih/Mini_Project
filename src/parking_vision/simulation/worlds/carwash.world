<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="carwash_world">

    <!-- gz-sim 8 필수 시스템 플러그인 -->
    <plugin filename="gz-sim8-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim8-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim8-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim8-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- 조명 -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 바닥 (회색 도로) -->
    <model name="ground">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>30 10</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>30 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== Phase 1: 정차구역 마커 (파란색) ====== -->
    <!-- 로봇 시작 위치(x=-5)에서 1m 앞(x=-4)에 위치 -->
    <model name="parking_marker">
      <static>true</static>
      <pose>-3.5 0 0.005 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1.0 1.5 0.01</size></box></geometry>
          <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0.2 1 1</diffuse>
            <emissive>0 0 0.6 1</emissive>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>1.0 1.5 0.01</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- 정차구역 테두리 표시 (흰색) -->
    <model name="parking_border_left">
      <static>true</static>
      <pose>-3.5 0.85 0.005 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1.4 0.1 0.01</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <emissive>0.5 0.5 0.5 1</emissive>
          </material>
        </visual>
      </link>
    </model>
    <model name="parking_border_right">
      <static>true</static>
      <pose>-3.5 -0.85 0.005 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1.4 0.1 0.01</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <emissive>0.5 0.5 0.5 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== Phase 2: 바닥 유도선 (흰색) ====== -->
    <!-- x=-3 (마커 끝) ~ x=2.5 (기둥 직전), 중앙선 -->
    <model name="guide_line">
      <static>true</static>
      <pose>-0.25 0 0.005 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>5.5 0.35 0.01</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <emissive>0.4 0.4 0.4 1</emissive>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>5.5 0.35 0.01</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ====== Phase 3: 세차장 입구 기둥 (주황색) ====== -->
    <model name="pillar_left">
      <static>true</static>
      <pose>3 1.2 1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.12</radius><length>2.0</length></cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder><radius>0.12</radius><length>2.0</length></cylinder>
          </geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
            <emissive>0.9 0.35 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <model name="pillar_right">
      <static>true</static>
      <pose>3 -1.2 1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.12</radius><length>2.0</length></cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder><radius>0.12</radius><length>2.0</length></cylinder>
          </geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
            <emissive>0.9 0.35 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 세차장 입구 바닥 레일 (노란색) -->
    <model name="rail_left">
      <static>true</static>
      <pose>3.5 1.0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1.5 0.06 0.04</size></box></geometry>
          <material>
            <ambient>1 1 0 1</ambient>
            <diffuse>1 1 0 1</diffuse>
            <emissive>0.5 0.5 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <model name="rail_right">
      <static>true</static>
      <pose>3.5 -1.0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>1.5 0.06 0.04</size></box></geometry>
          <material>
            <ambient>1 1 0 1</ambient>
            <diffuse>1 1 0 1</diffuse>
            <emissive>0.5 0.5 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 세차장 건물 벽 (배경) -->
    <model name="carwash_wall">
      <static>true</static>
      <pose>4.5 0 1.5 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.3 5 3</size></box></geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.3 5 3</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ====== 탑뷰 카메라 (전체 조감) ====== -->
    <model name="overhead_cam_model">
      <static>true</static>
      <pose>-1 0 10 0 1.5707963 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.15 0.15 0.1</size></box></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
        <sensor name="overhead_camera" type="camera">
          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.5</near>
              <far>100</far>
            </clip>
          </camera>
          <topic>/overhead/image_raw</topic>
        </sensor>
      </link>
    </model>

    <!-- ====== 로봇 차량 (납작한 AGV 스타일) ====== -->
    <!-- 시작: x=-5 (정차구역에서 1m 뒤), y=0.5 (측면 오프셋) -->
    <model name="robot_car">
      <pose>-5 0.5 0.1 0 0 0</pose>

      <!-- 차체 (납작한 AGV 형태) -->
      <link name="base_link">
        <inertial>
          <mass>5.0</mass>
          <inertia>
            <ixx>0.1</ixx><iyy>0.2</iyy><izz>0.2</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><box><size>0.6 0.4 0.12</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.6 0.4 0.12</size></box></geometry>
          <material>
            <ambient>0.1 0.6 0.2 1</ambient>
            <diffuse>0.1 0.6 0.2 1</diffuse>
            <emissive>0 0.1 0 1</emissive>
          </material>
        </visual>
      </link>

      <!-- 왼쪽 바퀴 -->
      <link name="left_wheel">
        <pose>0 0.22 0 -1.5707963 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.1</radius><length>0.04</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.1</radius><length>0.04</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- 오른쪽 바퀴 -->
      <link name="right_wheel">
        <pose>0 -0.22 0 -1.5707963 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.1</radius><length>0.04</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.1</radius><length>0.04</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- 카메라 링크 (전방 + 약간 하향, 바닥선 & 기둥 모두 감지) -->
      <link name="camera_link">
        <pose>0.35 0 0.18 0 0.3 0</pose>
        <sensor name="camera" type="camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
          <topic>/camera/image_raw</topic>
        </sensor>
      </link>

      <joint name="camera_joint" type="fixed">
        <parent>base_link</parent>
        <child>camera_link</child>
      </joint>

      <!-- DiffDrive 플러그인 -->
      <plugin filename="gz-sim8-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.44</wheel_separation>
        <wheel_radius>0.1</wheel_radius>
        <topic>/cmd_vel</topic>
      </plugin>

    </model>

  </world>
</sdf>
