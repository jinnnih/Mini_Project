<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="parking_robot_world">

    <!-- ====== 필수 시스템 플러그인 ====== -->
    <plugin filename="gz-sim8-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim8-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim8-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim8-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim8-contact-system"
            name="gz::sim::systems::Contact"/>

    <!-- 조명 -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ====== 바닥 ====== -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
          <material>
            <ambient>0.22 0.22 0.22 1</ambient>
            <diffuse>0.22 0.22 0.22 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== 세차 부스 ====== -->
    <!-- 남쪽 벽 -->
    <model name="booth_south_wall">
      <static>true</static>
      <pose>-2.5 -1.6 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5.2 0.15 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5.2 0.15 2.5</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
            <emissive>0.05 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 북쪽 벽 -->
    <model name="booth_north_wall">
      <static>true</static>
      <pose>-2.5 1.6 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5.2 0.15 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5.2 0.15 2.5</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
            <emissive>0.05 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 후면 벽 -->
    <model name="booth_back_wall">
      <static>true</static>
      <pose>-5.0 0 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.15 3.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.15 3.2 2.5</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
            <emissive>0.05 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 지붕 -->
    <model name="booth_roof">
      <static>true</static>
      <pose>-2.5 0 2.5 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>5.2 3.2 0.15</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
            <emissive>0.04 0.04 0.04 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== 정차된 차량 (static) ====== -->
    <!-- 차체 -->
    <model name="car_body">
      <static>true</static>
      <pose>3.0 0 0.58 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>4.2 1.8 0.5</size></box></geometry>
          <material>
            <ambient>0.1 0.25 0.65 1</ambient>
            <diffuse>0.1 0.25 0.65 1</diffuse>
            <emissive>0.02 0.05 0.13 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 앞바퀴 북쪽 (Phase 감지 타깃 — 주황 허브) -->
    <model name="fl_wheel">
      <static>true</static>
      <pose>1.5 0.78 0.3 1.5708 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
        </collision>
        <!-- 타이어 외형 -->
        <visual name="tire">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.06 0.06 0.06 1</ambient>
            <diffuse>0.06 0.06 0.06 1</diffuse>
            <emissive>0.02 0.02 0.02 1</emissive>
          </material>
        </visual>
        <!-- 주황 허브 (비전 감지 타깃) -->
        <visual name="hub">
          <geometry><box><size>0.22 0.24 0.22</size></box></geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
            <emissive>0.9 0.35 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 앞바퀴 남쪽 (Phase 감지 타깃 — 주황 허브) -->
    <model name="fr_wheel">
      <static>true</static>
      <pose>1.5 -0.78 0.3 1.5708 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
        </collision>
        <visual name="tire">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.06 0.06 0.06 1</ambient>
            <diffuse>0.06 0.06 0.06 1</diffuse>
            <emissive>0.02 0.02 0.02 1</emissive>
          </material>
        </visual>
        <visual name="hub">
          <geometry><box><size>0.22 0.24 0.22</size></box></geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
            <emissive>0.9 0.35 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 뒷바퀴 북쪽 (회색) -->
    <model name="rl_wheel">
      <static>true</static>
      <pose>4.5 0.78 0.3 1.5708 0 0</pose>
      <link name="link">
        <visual name="tire">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.12 0.12 0.12 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <emissive>0.02 0.02 0.02 1</emissive>
          </material>
        </visual>
        <visual name="hub">
          <geometry><box><size>0.22 0.24 0.22</size></box></geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
            <emissive>0.05 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- 뒷바퀴 남쪽 (회색) -->
    <model name="rr_wheel">
      <static>true</static>
      <pose>4.5 -0.78 0.3 1.5708 0 0</pose>
      <link name="link">
        <visual name="tire">
          <geometry><cylinder><radius>0.28</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.12 0.12 0.12 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <emissive>0.02 0.02 0.02 1</emissive>
          </material>
        </visual>
        <visual name="hub">
          <geometry><box><size>0.22 0.24 0.22</size></box></geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
            <emissive>0.05 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== 로봇 (4륜 메카넘) ====== -->
    <model name="robot_car">
      <pose>-4 0 0.055 0 0 0</pose>

      <!-- 본체 -->
      <link name="base_link">
        <inertial>
          <mass>8.0</mass>
          <inertia>
            <ixx>0.083</ixx><iyy>0.083</iyy><izz>0.13</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="body_visual">
          <geometry><box><size>0.58 0.46 0.08</size></box></geometry>
          <material>
            <ambient>0.1 0.75 0.1 1</ambient>
            <diffuse>0.1 0.75 0.1 1</diffuse>
            <emissive>0.02 0.15 0.02 1</emissive>
          </material>
        </visual>
        <collision name="body_collision">
          <geometry><box><size>0.58 0.46 0.08</size></box></geometry>
        </collision>

        <!-- 전면 카메라 센서 -->
        <sensor name="robot_camera" type="camera">
          <pose>0.29 0 0.06 0 -0.1 0</pose>
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <camera>
            <horizontal_fov>1.2</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip><near>0.05</near><far>20</far></clip>
          </camera>
          <topic>/camera/image_raw</topic>
        </sensor>
      </link>

      <!-- 앞 왼쪽 바퀴 (FL) -->
      <link name="fl_wheel_link">
        <pose>0.22 0.22 0.0 -1.5708 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.055</radius><length>0.05</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><sphere><radius>0.055</radius></sphere></geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_link">1 -1 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
      <joint name="fl_joint" type="revolute">
        <parent>base_link</parent>
        <child>fl_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        </axis>
      </joint>

      <!-- 앞 오른쪽 바퀴 (FR) -->
      <link name="fr_wheel_link">
        <pose>0.22 -0.22 0.0 -1.5708 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.055</radius><length>0.05</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><sphere><radius>0.055</radius></sphere></geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_link">1 1 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
      <joint name="fr_joint" type="revolute">
        <parent>base_link</parent>
        <child>fr_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        </axis>
      </joint>

      <!-- 뒤 왼쪽 바퀴 (RL) -->
      <link name="rl_wheel_link">
        <pose>-0.22 0.22 0.0 -1.5708 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.055</radius><length>0.05</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><sphere><radius>0.055</radius></sphere></geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_link">1 1 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
      <joint name="rl_joint" type="revolute">
        <parent>base_link</parent>
        <child>rl_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        </axis>
      </joint>

      <!-- 뒤 오른쪽 바퀴 (RR) -->
      <link name="rr_wheel_link">
        <pose>-0.22 -0.22 0.0 -1.5708 0 0</pose>
        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.055</radius><length>0.05</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><sphere><radius>0.055</radius></sphere></geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu><mu2>0.0</mu2>
                <fdir1 gz:expressed_in="base_link">1 -1 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
      <joint name="rr_joint" type="revolute">
        <parent>base_link</parent>
        <child>rr_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
        </axis>
      </joint>

      <!-- 메카넘 드라이브 플러그인 (360도 이동) -->
      <plugin filename="gz-sim-mecanum-drive-system"
              name="gz::sim::systems::MecanumDrive">
        <front_left_joint>fl_joint</front_left_joint>
        <front_right_joint>fr_joint</front_right_joint>
        <back_left_joint>rl_joint</back_left_joint>
        <back_right_joint>rr_joint</back_right_joint>
        <wheel_separation>0.44</wheel_separation>
        <wheelbase>0.44</wheelbase>
        <wheel_radius>0.055</wheel_radius>
        <min_acceleration>-5</min_acceleration>
        <max_acceleration>5</max_acceleration>
        <topic>cmd_vel</topic>
        <odom_topic>/model/robot_car/odometry</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>robot_car/base_link</child_frame_id>
        <odom_publish_frequency>10</odom_publish_frequency>
      </plugin>

    </model>

    <!-- ====== 탑뷰 카메라 ====== -->
    <model name="overhead_cam_model">
      <static>true</static>
      <pose>1.5 0 6.0 0 1.5707963 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.1 0.1 0.05</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
        <sensor name="overhead_camera" type="camera">
          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip><near>0.1</near><far>20</far></clip>
          </camera>
          <topic>/overhead/image_raw</topic>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
